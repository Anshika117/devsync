generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum FolderType {
  AUTO
  CUSTOM
}

model User {
  id              String            @id @default(cuid())
  email           String            @unique
  name            String?
  image           String?
  emailVerified   DateTime?
  createdAt       DateTime          @default(now())
  folders         Folder[]
  problems        Problem[]
  goals           Goal[]
  progressRecords ProblemProgress[] 
  activityLogs    ActivityLog[]
  revisionAlerts  RevisionAlert[]
  lcUsername      String?   // ADD THIS
  cfHandle        String?   // ADD THIS
  accounts        Account[]
  sessions        Session[]

}

model Folder {
  id        String          @id @default(cuid())
  name      String          // e.g., "Greedy", "Arrays" (AUTO) or "Google Prep" (CUSTOM)
  type      FolderType      @default(AUTO)
  userId    String
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  problems  FolderProblem[] 
  createdAt DateTime        @default(now())

  @@unique([userId, name, type]) 
}

model Problem {
  id          String          @id @default(cuid())
  title       String
  platform    String          // "LeetCode", "Codeforces", "CodeChef"
  difficulty  String          // Normalized: "Easy", "Medium", "Hard"
  tags        String[]        // Raw array of tags from platform APIs
  url         String          @unique 
  code        String?         @db.Text
  notes       String?         @db.Text
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  folders     FolderProblem[] 
  solvedAt    DateTime?
  createdAt   DateTime        @default(now())
  progress    ProblemProgress?

  @@index([userId])
  @@index([platform])
  @@index([difficulty])
}

model FolderProblem {
  id        String   @id @default(cuid())
  folderId  String
  problemId String
  folder    Folder   @relation(fields: [folderId], references: [id], onDelete: Cascade)
  problem   Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([folderId, problemId]) 
  @@index([folderId])
  @@index([problemId])
}

model ProblemProgress {
  id             String    @id @default(cuid())
  problemId      String    @unique
  problem        Problem   @relation(fields: [problemId], references: [id], onDelete: Cascade)
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  firstSolvedAt  DateTime  @default(now())
  lastViewedAt   DateTime  @default(now())
  lastRevisedAt  DateTime?
  
  revisionCount  Int       @default(0)
  mistakeCount   Int       @default(0)
  retentionScore Float     @default(0.0) 

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([userId])
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String   // "LEETCODE_SYNC", "AI_CLASSIFICATION", "EMBEDDING_GEN"
  status    String   // "PENDING", "PROCESSING", "SUCCESS", "FAILED"
  error     String?  @db.Text
  createdAt DateTime @default(now())
}

model RevisionAlert {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic         String   // e.g., "Dynamic Programming"
  questionCount Int
  avgScore      Float
  generatedAt   DateTime @default(now())
}

model Goal {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  weeklyEasy  Int      @default(0)
  weeklyMed   Int      @default(0)
  weeklyHard  Int      @default(0)
  doneEasy    Int      @default(0)
  doneMed     Int      @default(0)
  doneHard    Int      @default(0)
  createdAt   DateTime @default(now())
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}