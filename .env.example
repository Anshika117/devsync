# Supabase PostgreSQL — pooled connection, used by the app at runtime (port 6543)
DATABASE_URL=

# Supabase PostgreSQL — direct connection, used by Prisma CLI for migrations (port 5432)
DIRECT_URL=

# NextAuth v5
# Generate with: openssl rand -base64 32
AUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true

# Google OAuth (console.cloud.google.com → Credentials → OAuth client ID)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Gemini API key (aistudio.google.com/apikey) — powers /api/hint/rag
GEMINI_API_KEY=

# Upstash Redis (upstash.com) — caches AI hints and rate-limits hint requests
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Sentry (sentry.io) — error tracking. Both DSN vars are the same value from
# your Sentry project's Client Keys page; NEXT_PUBLIC_ makes the browser
# bundle able to read it (client-side errors), the unprefixed one is read
# server-side (instrumentation.ts / sentry.server.config.ts). Leaving these
# blank is safe — Sentry.init() with an empty DSN just no-ops, nothing breaks.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Optional — only needed for next.config.ts's withSentryConfig to upload
# source maps at build time, so stack traces in Sentry show real source
# lines instead of minified output. Safe to leave blank locally; without
# them the build just skips the upload step.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
